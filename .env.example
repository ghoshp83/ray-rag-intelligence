# Copy to .env and fill in. .env is gitignored (Hard Rule 7) — never commit real keys.

# --- GenAI generation (happy path) ---
ANTHROPIC_API_KEY=sk-ant-...
RAYRAG_LLM_MODEL=claude-opus-4-8

# --- Retrieval / models (defaults are sensible; override to experiment) ---
RAYRAG_EMBED_MODEL=BAAI/bge-small-en-v1.5
RAYRAG_RERANKER_PATH=artifacts/reranker
RAYRAG_INTENT_PATH=artifacts/intent_clf
RAYRAG_INDEX_PATH=artifacts/index.faiss

# --- Retrieval depths ---
RAYRAG_RETRIEVE_TOP_K=50
RAYRAG_RERANK_TOP_K=5

# --- Data ---
RAYRAG_CORPUS_PATH=data/corpus
RAYRAG_EVAL_PATH=data/eval/relevance.jsonl
