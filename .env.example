# Copy to .env and fill in. .env is gitignored (Hard Rule 7) — never commit real keys.

# --- GenAI generation (happy path) ---
ANTHROPIC_API_KEY=sk-ant-...
RAYRAG_LLM_MODEL=claude-opus-4-8

# --- Retrieval / models (defaults are sensible; override to experiment) ---
RAYRAG_EMBED_MODEL=BAAI/bge-small-en-v1.5
RAYRAG_RERANKER_PATH=artifacts/reranker.json
RAYRAG_INTENT_PATH=artifacts/intent_clf.joblib
RAYRAG_INDEX_PATH=artifacts/index.faiss
RAYRAG_EVAL_REPORT_PATH=artifacts/eval_report.json

# --- Retrieval depths ---
RAYRAG_RETRIEVE_TOP_K=50
RAYRAG_RERANK_TOP_K=5

# --- Data ---
RAYRAG_CORPUS_PATH=data/corpus
# Reranker labels are split: train_path tunes+fits the ranker, eval_path is the
# disjoint held-out test set the harness scores (so nDCG/MRR is not a train-set number).
RAYRAG_EVAL_TRAIN_PATH=data/eval/relevance_train.jsonl
RAYRAG_EVAL_PATH=data/eval/relevance_test.jsonl
RAYRAG_INTENTS_PATH=data/intents/intents.jsonl
